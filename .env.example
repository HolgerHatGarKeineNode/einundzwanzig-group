APP_NAME=EINUNDZWANZIG
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Fixierter Default-Space der Web-Client-Insel (leer = lokaler Test-Relay).
# Prod: wss://group.einundzwanzig.space/
NOSTR_SPACE_URL=

APP_LOCALE=de
APP_FALLBACK_LOCALE=de
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

# Wegwerf-nsec NUR für E2E-Login-Tests (M1.5) — kein realer Key, kein Wert.
NOSTR_TEST_NSEC=nsec1wmtsjwzs3zm4q9cg2fcpg0z99yxq649kyp8yl8cgm4jmsjscppfs43avez

SESSION_DRIVER=database
# 1 Jahr (60*24*365) — der Nostr-Login (via NIP-98-Handoff) soll Wiederkehr nach
# Tagen/Wochen überleben, nicht nach 2h neu signieren müssen. DB-Sessions rollieren
# automatisch (last_activity pro Request), Cookie-Max-Age leitet Laravel daraus ab.
SESSION_LIFETIME=525600
# false pinnen: bei true stürbe das Cookie beim Browser-Schließen (Session-Cookie).
SESSION_EXPIRE_ON_CLOSE=false
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# ── NativePHP Mobile ────────────────────────────────────────────────────
NATIVEPHP_APP_ID=space.einundzwanzig.group
NATIVEPHP_APP_VERSION=DEBUG
NATIVEPHP_APP_VERSION_CODE=1
NATIVEPHP_START_URL=/nostr-smoke
NATIVEPHP_DEEPLINK_SCHEME=einundzwanziggroup
NATIVEPHP_DEEPLINK_HOST=group.einundzwanzig.space
NATIVEPHP_ANDROID_COLOR_PRIMARY="#F7931A"
NATIVEPHP_ANDROID_COLOR_PRIMARY_NIGHT="#F7931A"
NATIVEPHP_ANDROID_COLOR_ON_PRIMARY="#0A0A0A"
NATIVEPHP_ANDROID_SDK_LOCATION=/home/user/Android/Sdk
